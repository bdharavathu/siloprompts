# SiloPrompts Environment Configuration
# Copy this file to .env and update values as needed
# IMPORTANT: Never commit the .env file to version control

# Flask Configuration
FLASK_ENV=production
# Generate a strong secret key (use: python -c 'import secrets; print(secrets.token_hex(32))')
SECRET_KEY=your-secret-key-here-change-in-production

# Paths
# For Docker: use /app/prompts and /app/data
# For local development: use absolute paths to your directories
PROMPTS_DIR=/app/prompts
DATA_DIR=/app/data

# Server Configuration
PORT=5000

# Optional: Git Integration (for future use)
# GIT_ENABLED=false
# GIT_AUTO_COMMIT=false
